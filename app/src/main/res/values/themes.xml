<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Jurnalify" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Warna primer -->
        <item name="colorPrimary">#4176FF</item>
        <item name="colorPrimaryVariant">#1A56F0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        <!-- Warna background -->
        <item name="android:windowBackground">@android:color/white</item>
        
        <!-- Warna teks -->
        <item name="android:textColor">#333333</item>
    </style>

    <style name="Theme.Jurnalify" parent="Base.Theme.Jurnalify" />
    
    <!-- Tema tanpa action bar -->
    <style name="Theme.Jurnalify.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>