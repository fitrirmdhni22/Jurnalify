<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Bendera Negara (Emoji Besar) -->
        <TextView
            android:id="@+id/textLargeFlag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌍"
            android:textSize="120sp" />

        <!-- Nama Negara -->
        <TextView
            android:id="@+id/textCountryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="NEGARA: MENDETEKSI..."
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Ucapan Sapaan (Say Hi) -->
        <TextView
            android:id="@+id/textGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hello! Welcome"
            android:textColor="#4B5563"
            android:textSize="22sp"
            android:textStyle="italic" />

        <!-- Tombol Masuk ke Jurnal -->
        <Button
            android:id="@+id/buttonContinue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:backgroundTint="#4176FF"
            android:paddingHorizontal="32dp"
            android:text="Masuk ke Jurnal"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
