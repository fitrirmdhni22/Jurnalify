<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FF">

    <LinearLayout
        android:id="@+id/editContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:background="#F9FBFF"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bar atas: back dan judul halaman -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/buttonBackEdit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:src="@drawable/back_chevron"
                android:contentDescription="Kembali"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/textEditTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Jurnal"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/textEditSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perbarui cerita anda"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Label Judul jurnal -->
        <TextView
            android:id="@+id/labelEditTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Judul jurnal"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <!-- Input judul jurnal -->
        <EditText
            android:id="@+id/editJournalTitle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#111827"
            android:textSize="14sp"
            android:inputType="textCapSentences" />

        <!-- Label Isi jurnal -->
        <TextView
            android:id="@+id/labelEditContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Isi jurnal"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <!-- Input isi jurnal -->
        <EditText
            android:id="@+id/editJournalContent"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:padding="14dp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:textColor="#111827"
            android:textSize="14sp" />

        <!-- Tombol Update & Batal di bawah -->
        <Button
            android:id="@+id/buttonApplyUpdate"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_save_entry"
            android:text="Update Jurnal"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <Button
            android:id="@+id/buttonCancelUpdate"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_save_entry"
            android:text="Batalkan"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
